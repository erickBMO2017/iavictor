---
import Layout from '../layouts/Layout.astro';

const offers = [
	{
		title: 'Pack Completo de Prompts',
		description:
			'Accede a los mejores prompts listos para Instagram, TikTok y contenido viral.',
		price: 'US$1',
		oldPrice: 'US$15',
		discount: '93% OFF',
		href: '/compra',
		features: ['Prompts exclusivos', 'Acceso inmediato', 'Guía completa'],
		cta: 'Comprar Ahora por $1',
	},
];

const socialStats = [
	{ value: '150K+', label: 'Seguidores' },
	{ value: '500K+', label: 'Likes' },
	{ value: '10K+', label: 'Comentarios' },
];

const perks = [
	{
		title: 'Acceso Inmediato',
		text: 'Recibe todo el pack de prompts en tu correo al instante tras realizar la compra.',
	},
	{
		title: 'Calidad Premium',
		text: 'Productos creados con tecnologías de IA modernas y enfoque en resultados.',
	},
	{
		title: 'Soporte Dedicado',
		text: 'Atención personalizada para resolver dudas y acompañarte en todo el proceso.',
	},
];

const testimonials = [
	{
		name: 'Carlos Ruiz',
		meta: 'Creador de Contenido',
		quote:
			'Este pack de prompts me ahorró muchísimas horas de trabajo. Las ideas que genera la IA son increíbles.',
	},
	{
		name: 'Amanda Reis',
		meta: 'Influencer Digital',
		quote:
			'Mis copys y guiones quedaron con un nivel profesional en pocos minutos. ¡Súper recomendado!',
	},
	{
		name: 'Juliana Santos',
		meta: 'Especialista en Marketing',
		quote:
			'Por solo un dólar, el valor que aporta este pack es ridículo. Totalmente recomendado para agencias.',
	},
];
---

<Layout>
	<div class="home">
		<section class="hero" aria-label="Hero principal">
			<p class="hero-kicker" data-i18n="heroKicker">Prompts Profesionales para IA</p>
			<h1 data-i18n="heroTitle">Domina la creación de contenido con nuestro Pack de Prompts</h1>
			<p class="hero-lead" data-i18n="heroLead">
				Convierte tus ideas en contenido viral con acceso inmediato, calidad premium y resultados garantizados. Empieza hoy por solo $1.
			</p>
			<div class="hero-actions">
				<a href="/compra" class="btn primary" data-i18n="heroCta">Comprar el Pack a $1</a>
			</div>
		</section>

		<section class="offers" aria-label="Productos principales">
			<h2 data-i18n="offersTitle">Pack Completo de Prompts</h2>
			{
				offers.map((offer, index) => (
					<article class="offer-card">
						<h2 data-i18n={`offer-${index}-title`}>{offer.title}</h2>
						<p class="offer-description" data-i18n={`offer-${index}-description`}>{offer.description}</p>
						<ul>
							{offer.features.map((item, featIndex) => (
								<li data-i18n={`offer-${index}-feature-${featIndex}`}>{item}</li>
							))}
						</ul>
						<div class="offer-footer">
							<div class="price-wrap">
								<span class="price" data-i18n={`offer-${index}-price`}>{offer.price}</span>
								{offer.oldPrice && <span class="old-price" data-i18n={`offer-${index}-oldPrice`}>{offer.oldPrice}</span>}
								{offer.discount && <span class="badge" data-i18n={`offer-${index}-discount`}>{offer.discount}</span>}
							</div>
							<a href={offer.href} class="btn ghost" data-i18n={`offer-${index}-cta`}>{offer.cta}</a>
						</div>
					</article>
				))
			}
		</section>

		<section class="social-proof" aria-label="Métricas de redes">
			<h2 data-i18n="socialTitle">+150.000 personas siguen nuestro trabajo</h2>
			<p data-i18n="socialLead">Únete a la comunidad y mira lo que está diciendo.</p>
			<div class="stats-grid">
				{
					socialStats.map((item, index) => (
						<div class="stat-item">
							<strong>{item.value}</strong>
							<span data-i18n={`social-${index}-label`}>{item.label}</span>
						</div>
					))
				}
			</div>
		</section>

		<section class="perks" aria-label="Por qué elegirnos">
			<h2 data-i18n="perksTitle">Solene Prompt</h2>
			<p data-i18n="perksLead">Calidad, rapidez y soporte dedicado en cada entrega.</p>
			<div class="perks-grid">
				{
					perks.map((perk, index) => (
						<article class="perk-card">
							<h3 data-i18n={`perk-${index}-title`}>{perk.title}</h3>
							<p data-i18n={`perk-${index}-text`}>{perk.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="testimonials" aria-label="Testimonios">
			<h2 data-i18n="testimonialsTitle">Historias reales de personas que transformaron sus ideas</h2>
			<div class="testimonials-grid">
				{
					testimonials.map((item, index) => (
						<article class="testimonial-card">
							<p data-i18n={`testimonial-${index}-quote`}>“{item.quote}”</p>
							<div>
								<strong data-i18n={`testimonial-${index}-name`}>{item.name}</strong>
								<span data-i18n={`testimonial-${index}-meta`}>{item.meta}</span>
							</div>
						</article>
					))
				}
			</div>
		</section>
	</div>
</Layout>

<style>
	.home {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 1rem 0;
	}

	.hero {
		text-align: center;
		padding: 2rem 1rem;
	}

	.hero-kicker {
		margin: 0;
		font-weight: 700;
		color: var(--terracota-solene);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	h1 {
		margin: 0.35rem 0 0;
		font-size: clamp(2rem, 4.5vw, 3rem);
		line-height: 1.2;
		/* The color is inherited from the global style (pizarra-profunda) */
	}

	.hero-lead {
		margin: 1rem auto 0;
		color: var(--carbon-cinematografico);
		line-height: 1.6;
		max-width: 62ch;
		font-size: 1.1rem;
	}

	.hero-actions {
		margin-top: 1.5rem;
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.8rem 1.75rem;
		border-radius: 999px;
		font-weight: 700;
		border: 2px solid transparent;
		transition: transform 0.2s ease;
		font-family: 'Montserrat', sans-serif;
	}
	
	.btn:hover {
		transform: scale(1.03);
	}

	.btn.primary {
		background: var(--oro-kodak);
		color: var(--carbon-cinematografico);
	}

	.btn.secondary,
	.btn.ghost {
		background: transparent;
		border-color: var(--pizarra-profunda);
		color: var(--pizarra-profunda);
	}

	.offers {
		display: grid;
		grid-template-columns: minmax(0, 600px);
		justify-content: center;
		gap: 1rem;
		padding: 1rem 0;
	}

	.offer-card {
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 1rem;
		padding: 1.5rem;
		background: var(--blanco-editorial);
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		box-shadow: 0 10px 30px -15px color-mix(in srgb, var(--pizarra-profunda) 20%, transparent);
	}

	.offer-card h2,
	.social-proof h2,
	.perks h2,
	.testimonials h2 {
		margin: 0;
		font-size: 1.5rem;
		/* Color is inherited */
	}

	.offer-description,
	.social-proof p,
	.perks > p {
		margin: 0;
		color: var(--carbon-cinematografico);
		line-height: 1.55;
	}

	.offer-card ul {
		margin: 0;
		padding-left: 1.2rem;
		color: var(--carbon-cinematografico);
		display: grid;
		gap: 0.35rem;
	}

	.offer-footer {
		margin-top: auto;
		padding-top: 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		flex-wrap: wrap;
	}

	.price-wrap {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.price {
		font-size: 1.5rem;
		font-weight: 800;
		font-family: 'Oswald', sans-serif;
		color: var(--carbon-cinematografico);
	}

	.old-price {
		text-decoration: line-through;
		color: color-mix(in srgb, var(--carbon-cinematografico) 50%, transparent);
		font-weight: 600;
	}

	.badge {
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		color: var(--blanco-editorial);
		background: var(--terracota-solene);
	}
	
	.social-proof,
	.perks,
	.testimonials {
		padding: 2rem 1rem;
		text-align: center;
	}

	.stats-grid,
	.perks-grid,
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
		text-align: left;
	}

	.stat-item,
	.perk-card,
	.testimonial-card {
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 0.85rem;
		padding: 1.25rem;
		background: var(--blanco-editorial);
	}

	.stat-item {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
		text-align: center;
	}

	.stat-item strong {
		font-family: 'Oswald', sans-serif;
		font-size: 1.75rem;
		line-height: 1.1;
		color: var(--terracota-solene);
	}

	.stat-item span {
		color: var(--carbon-cinematografico);
		font-weight: 600;
	}

	.perk-card h3 {
		margin: 0;
		font-size: 1.1rem;
		/* Color is inherited */
	}

	.perk-card p,
	.testimonial-card p {
		margin: 0.55rem 0 0;
		color: color-mix(in srgb, var(--carbon-cinematografico) 80%, transparent);
		line-height: 1.55;
	}

	.testimonial-card {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.testimonial-card p {
		margin: 0;
		color: color-mix(in srgb, var(--carbon-cinematografico) 80%, transparent);
		font-style: italic;
	}

	.testimonial-card strong {
		display: block;
	}

	.testimonial-card span {
		color: color-mix(in srgb, var(--carbon-cinematografico) 60%, transparent);
		font-size: 0.9rem;
	}

	.testimonial-card div {
		margin-top: auto;
		padding-top: 0.5rem;
		border-top: 1px solid color-mix(in srgb, var(--carbon-cinematografico) 20%, transparent);
	}


	@media (max-width: 900px) {
		.stats-grid,
		.perks-grid,
		.testimonials-grid {
			grid-template-columns: 1fr;
		}

		.hero,
		.social-proof,
		.perks,
		.testimonials,
		.offer-card {
			padding: 1.5rem 1rem;
		}
	}
</style>
