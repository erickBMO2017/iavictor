---
import Layout from '../layouts/Layout.astro';

const sampleImages = [
	'Viaje a Venecia',
	'Año Nuevo 2026',
	'Graduación Infantil',
	'Retrato Profesional',
	'Viaje a Tailandia',
	'Vacaciones en Maldivas',
];

const included = [
	{
		title: 'Prompts de Instagram',
		text: 'Todos los prompts públicos del perfil organizados y listos para usar.',
	},
	{
		title: 'Prompts Exclusivos',
		text: 'Prompts premium que no están en Instagram, creados para este pack.',
	},
	{
		title: 'Actualizaciones Gratis',
		text: 'Acceso a nuevos prompts públicos que se publiquen en el futuro.',
	},
	{
		title: 'Guía Nano Banana',
		text: 'Tutorial completo para generar imágenes con mejor calidad.',
	},
	{
		title: 'Tips de Fotografía',
		text: 'Cómo tomar fotos con mejores resultados para IA.',
	},
];

const steps = [
	{
		number: '1',
		title: 'Haz tu compra',
		text: 'Pago seguro con tarjeta o PIX para activar acceso inmediato.',
	},
	{
		number: '2',
		title: 'Accede a los prompts',
		text: 'Recibes por email tu enlace personal a la biblioteca completa.',
	},
	{
		number: '3',
		title: 'Crea imágenes increíbles',
		text: 'Usa los prompts en Gemini, Midjourney u otra IA que prefieras.',
	},
];

const bullets = [
	'+500 prompts incluidos',
	'Acceso de por vida al documento',
	'Actualizaciones gratuitas',
	'Soporte prioritario por WhatsApp',
	'Instrucciones simples de uso',
	'Compatible con principales IAs',
];

const testimonials = [
	{
		quote:
			'Los prompts son increíbles. Transformé mis fotos simples en imágenes de revista y fue súper fácil.',
		name: 'Amanda Reis',
		meta: 'Influencer Digital',
	},
	{
		quote:
			'Por fin tengo fotos profesionales para LinkedIn sin pagar fotógrafo. Excelente inversión.',
		name: 'Bruno Oliveira',
		meta: 'Consultor de Negocios',
	},
];
---

<Layout>
	<div class="prompts-page">
		<section class="hero" aria-label="Hero prompts">
			<p class="kicker">Oferta especial por tiempo limitado</p>
			<h1>+500 prompts para transformar tus fotos</h1>
			<p>
				Más de 500 prompts de Instagram + exclusivos + guía completa para crear imágenes
				impactantes con IA.
			</p>
			<div class="price-box">
				<span class="old">De US$15</span>
				<strong>US$1</strong>
				<span class="badge">93% OFF</span>
			</div>
			<div class="payment">Forma de pago: PayPal o Tarjeta</div>
			<a href="/compra" class="btn primary">Comprar Ahora por $1</a>
			<small>Acceso inmediato · Pago 100% seguro</small>
		</section>

		<section class="samples" aria-label="Ejemplos de imágenes">
			<h2>Imágenes reales generadas con el pack</h2>
			<div class="samples-grid">
				{
					sampleImages.map((item) => (
						<article class="sample-card">
							<div class="image-placeholder">IMG</div>
							<h3>{item}</h3>
						</article>
					))
				}
			</div>
		</section>

		<section class="included" aria-label="Incluye">
			<h2>Todo lo que necesitas</h2>
			<p>Un pack completo para transformar tus fotos con IA.</p>
			<div class="included-grid">
				{
					included.map((item) => (
						<article class="included-card">
							<h3>{item.title}</h3>
							<p>{item.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="how" aria-label="Cómo funciona">
			<h2>Cómo funciona</h2>
			<div class="how-grid">
				{
					steps.map((step) => (
						<article class="step-card">
							<span class="step-number">{step.number}</span>
							<h3>{step.title}</h3>
							<p>{step.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="pack" id="comprar" aria-label="Pack de prompts">
			<h2>Pack Completo de Prompts</h2>
			<p>
				Acceso inmediato a todos los prompts, guías y actualizaciones futuras. Todo lo que
				necesitas para crear imágenes increíbles con IA.
			</p>
			<ul>
				{
					bullets.map((item) => (
						<li>{item}</li>
					))
				}
			</ul>
			<div class="pack-footer">
				<div class="price-box">
					<span class="old">US$15</span>
					<strong>US$1</strong>
				</div>
				<a href="/compra" class="btn primary">Comprar Ahora - US$1</a>
			</div>
			<small>Soporte por WhatsApp · Pago 100% seguro</small>
		</section>

		<section class="testimonials" aria-label="Testimonios">
			<h2>Historias reales de clientes</h2>
			<div class="testimonials-grid">
				{
					testimonials.map((item) => (
						<article class="testimonial-card">
							<p>“{item.quote}”</p>
							<div>
								<strong>{item.name}</strong>
								<span>{item.meta}</span>
							</div>
						</article>
					))
				}
			</div>
		</section>
	</div>
</Layout>

<style>
	.prompts-page {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		padding: 1rem 0;
	}

	.hero {
		text-align: center;
		padding: 2rem 1rem;
		background-color: var(--blanco-editorial);
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 1rem;
	}
	
	.samples,
	.included,
	.how,
	.pack,
	.testimonials {
		padding: 2rem 1rem;
		text-align: center;
	}

	.kicker {
		margin: 0;
		font-weight: 700;
		color: var(--terracota-solene);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	h1 {
		margin: 0.35rem 0 0;
		font-size: clamp(2rem, 4.5vw, 3rem);
		line-height: 1.2;
	}
	
	h2 {
		margin: 0;
		font-size: 1.75rem;
	}

	h3 {
		margin: 0;
		font-size: 1.1rem;
	}

	p {
		line-height: 1.6;
		color: var(--carbon-cinematografico);
		max-width: 65ch;
		margin-left: auto;
		margin-right: auto;
	}
	
	.hero p {
		font-size: 1.1rem;
		margin-top: 1rem;
	}

	.price-box {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		margin-top: 1rem;
		flex-wrap: wrap;
		background: var(--carbon-cinematografico);
		color: var(--blanco-editorial);
		padding: 0.5rem 1rem;
		border-radius: 0.75rem;
	}

	.old {
		text-decoration: line-through;
		color: color-mix(in srgb, var(--blanco-editorial) 50%, transparent);
		font-weight: 700;
	}

	.price-box strong {
		font-size: 1.75rem;
		font-family: 'Oswald', sans-serif;
	}

	.badge {
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		font-size: 0.75rem;
		font-weight: 800;
		letter-spacing: 0.02em;
		color: var(--carbon-cinematografico);
		background: var(--oro-kodak);
	}

	.payment {
		margin-top: 0.8rem;
		font-weight: 700;
		color: var(--carbon-cinematografico);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.8rem 1.75rem;
		border-radius: 999px;
		font-weight: 700;
		border: 2px solid transparent;
		transition: transform 0.2s ease;
		margin-top: 1rem;
		font-family: 'Montserrat', sans-serif;
	}

	.btn.primary {
		background: var(--oro-kodak);
		color: var(--carbon-cinematografico);
	}
	
	.btn:hover {
		transform: scale(1.03);
	}

	small {
		display: block;
		margin-top: 0.75rem;
		color: color-mix(in srgb, var(--carbon-cinematografico) 70%, transparent);
		font-weight: 600;
	}

	.samples-grid,
	.included-grid,
	.how-grid,
	.testimonials-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
		text-align: left;
	}
	
	.included p,
	.pack p {
		margin: 0.5rem 0 0;
	}

	.sample-card,
	.included-card,
	.step-card {
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 0.85rem;
		padding: 1.25rem;
		background: var(--blanco-editorial);
	}

	.image-placeholder {
		height: 110px;
		border-radius: 0.65rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: color-mix(in srgb, var(--pizarra-profunda) 10%, transparent);
		color: var(--pizarra-profunda);
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.included-card p,
	.step-card p,
	.testimonial-card p {
		margin: 0.55rem 0 0;
		color: color-mix(in srgb, var(--carbon-cinematografico) 80%, transparent);
	}

	.step-number {
		display: inline-block;
		font-weight: 700;
		font-family: 'Oswald', sans-serif;
		color: var(--carbon-cinematografico);
		background: color-mix(in srgb, var(--oro-kodak) 40%, transparent);
		border-radius: 0.5rem;
		padding: 0.1rem 0.6rem;
		margin-bottom: 0.75rem;
	}
	
	.pack {
		background: var(--carbon-cinematografico);
		color: var(--blanco-editorial);
		border-radius: 1rem;
	}
	
	.pack h2, .pack p, .pack li, .pack strong {
		color: var(--blanco-editorial);
	}
	
	.pack .old {
		color: color-mix(in srgb, var(--blanco-editorial) 50%, transparent);
	}
	
	.pack .btn.primary {
		background: var(--oro-kodak);
		color: var(--carbon-cinematografico);
	}

	.pack ul {
		margin: 1.5rem auto 0;
		padding: 0;
		list-style: none;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem 1rem;
		max-width: 600px;
		text-align: left;
	}
	
	.pack ul li {
		padding-left: 1.5rem;
		position: relative;
	}
	
	.pack ul li::before {
		content: '✓';
		position: absolute;
		left: 0;
		top: 0;
		color: var(--oro-kodak);
	}

	.pack-footer {
		margin-top: 1.5rem;
		padding-top: 1.5rem;
		border-top: 1px solid color-mix(in srgb, var(--blanco-editorial) 20%, transparent);
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}
	
	.pack-footer .price-box {
		background: none;
	}

	.testimonial-card {
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 0.85rem;
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		background-color: var(--blanco-editorial);
	}
	
	.testimonial-card p {
		font-style: italic;
		margin: 0;
	}

	.testimonial-card strong {
		display: block;
	}

	.testimonial-card span {
		color: color-mix(in srgb, var(--carbon-cinematografico) 60%, transparent);
		font-size: 0.92rem;
	}

	.testimonial-card div {
		margin-top: auto;
		padding-top: 0.5rem;
	}

	@media (max-width: 900px) {
		.samples-grid,
		.included-grid,
		.how-grid,
		.testimonials-grid,
		.pack ul {
			grid-template-columns: 1fr;
		}

		.hero,
		.samples,
		.included,
		.how,
		.pack,
		.testimonials {
			padding: 1.5rem 1rem;
		}
	}
</style>