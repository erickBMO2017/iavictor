---
import Layout from '../layouts/Layout.astro';

const orderID = Astro.url.searchParams.get('orderID');
---

<Layout>
	<div class="result-page success">
		<section class="result-card" aria-label="Pago exitoso">
			<p class="tag" data-i18n="successTag">Pago completado</p>
			<h1 data-i18n="successTitle">¡Gracias por tu compra!</h1>
			<p data-i18n="successLead">
				Tu pago fue aprobado correctamente. En breve recibirás acceso a tu contenido en el correo
				registrado.
			</p>
			{orderID && <p class="order"><span data-i18n="successOrderPrefix">ID de orden:</span> {orderID}</p>}
			<div class="actions">
				<a href="/prompts" class="btn secondary" data-i18n="successButton1">Volver a Prompts</a>
				<a href="https://wa.me/18438226879" target="_blank" rel="noreferrer noopener" class="btn primary" data-i18n="successButton2">Contactar Soporte</a>
			</div>
		</section>
	</div>
</Layout>

<style>
	.result-page {
		display: flex;
		justify-content: center;
		padding: 2rem 1rem;
	}

	.result-card {
		width: min(720px, 100%);
		border: 1px solid color-mix(in srgb, var(--pizarra-profunda) 15%, transparent);
		border-radius: 1rem;
		padding: 1.5rem;
		background: var(--blanco-editorial);
	}

	.tag {
		margin: 0;
		display: inline-flex;
		padding: 0.3rem 0.75rem;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 700;
		font-family: 'Montserrat', sans-serif;
		background: color-mix(in srgb, var(--oro-kodak) 25%, transparent);
		color: color-mix(in srgb, var(--oro-kodak) 95%, black 30%);
	}

	h1 {
		margin: 0.75rem 0 0;
		font-size: clamp(1.6rem, 3.3vw, 2.2rem);
	}

	p {
		margin: 0.75rem 0 0;
		line-height: 1.6;
		color: var(--carbon-cinematografico);
	}

	.order {
		font-weight: 700;
	}

	.actions {
		margin-top: 1.5rem;
		display: flex;
		gap: 0.6rem;
		flex-wrap: wrap;
	}

	/* Buttons are styled via global .btn classes */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.8rem 1.75rem;
		border-radius: 999px;
		font-weight: 700;
		border: 2px solid transparent;
		transition: transform 0.2s ease;
		font-family: 'Montserrat', sans-serif;
	}
	
	.btn:hover {
		transform: scale(1.03);
	}

	.btn.primary {
		background: var(--oro-kodak);
		color: var(--carbon-cinematografico);
	}

	.btn.secondary {
		background: transparent;
		border-color: var(--pizarra-profunda);
		color: var(--pizarra-profunda);
	}
</style>