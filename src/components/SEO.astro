---
// src/components/SEO.astro
import { Astro } from 'astro:env/server'; // Importa Astro para acceder a Astro.url y Astro.site
import { defaultLang } from '../i18n/ui'; // Importa el idioma por defecto para el atributo og:locale

interface Props {
  title: string;
  description: string;
  image?: string; // URL opcional de la imagen para Open Graph y Twitter Cards
  canonicalURL?: URL; // URL canónica opcional, por defecto será la URL actual de la página
  ogType?: 'website' | 'article'; // Tipo de contenido para Open Graph
}

const {
  title,
  description,
  image,
  canonicalURL,
  ogType = 'website', // Por defecto, el tipo es 'website'
} = Astro.props;

// Determina el locale actual para el atributo og:locale
const currentLocale = Astro.currentLocale || defaultLang;

// Imagen por defecto para Open Graph y Twitter Cards
// Asegúrate de tener una imagen en `public/social-share-default.jpg`
const defaultImage = '/social-share-default.jpg';

// Construye la URL completa de la imagen, asegurando que sea absoluta
const fullImageUrl = new URL(image || defaultImage, Astro.url.origin).href;

// Construye la URL canónica. Si no se proporciona, usa la URL completa de la página actual (incluyendo el prefijo de idioma).
const finalCanonicalURL = canonicalURL?.href || Astro.url.href;

// Para Open Graph URL, usa la URL completa de la página actual (incluyendo el prefijo de idioma).
const ogUrl = Astro.url.href;

// Tipo de tarjeta de Twitter
const twitterCardType = 'summary_large_image';
---

<!-- Meta Tags Estándar -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Canonical URL -->
<link rel="canonical" href={finalCanonicalURL} />

<!-- Open Graph Tags -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={ogUrl} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={currentLocale} />

<!-- Twitter Card Tags -->
<meta name="twitter:card" content={twitterCardType} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={title} />
<!-- Opcional: twitter:site y twitter:creator para handles de Twitter -->
<!-- <meta name="twitter:site" content="@yourtwitterhandle" /> -->
<!-- <meta name="twitter:creator" content="@yourtwitterhandle" /> -->