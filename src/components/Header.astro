---
const pathname = Astro.url.pathname;

const links = [
	{ href: '/', label: 'Inicio', icon: 'home' },
	{ href: '/prompts', label: 'Prompts', icon: 'sparkles' },
	{ href: '/faq', label: 'FAQ', icon: 'faq' },
];

const isActive = (href) => (href === '/' ? pathname === '/' : pathname.startsWith(href));

const icons = {
	home: 'M3.75 9.75 12 3l8.25 6.75v9a.75.75 0 0 1-.75.75H15V14.25a.75.75 0 0 0-.75-.75h-4.5a.75.75 0 0 0-.75.75V19.5H4.5a.75.75 0 0 1-.75-.75v-9Z',
	sparkles:
		'M12 3.75 13.875 8.25 18.375 10.125 13.875 12 12 16.5 10.125 12 5.625 10.125 10.125 8.25 12 3.75Zm7.5 10.5.938 2.063 2.062.937-2.062.938-.938 2.062-.937-2.062-2.063-.938 2.063-.937.937-2.063ZM4.5 13.5l.75 1.5 1.5.75-1.5.75-.75 1.5-.75-1.5-1.5-.75 1.5-.75.75-1.5Z',
	faq: 'M12 18h.008v.008H12V18Zm-2.25-9a2.25 2.25 0 1 1 3.973 1.44c-.563.63-1.473 1.166-1.473 2.31v.75',
};
---

<header class="site-header">
	<div class="header-inner">
		<a class="brand" href="/" aria-label="Ir a inicio">
			<span class="brand-mark">S</span>
			<span class="brand-text">Solene Prompt</span>
		</a>

		<button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Abrir menú">
			<span></span>
			<span></span>
			<span></span>
		</button>

		<nav class="desktop-nav" aria-label="Navegación principal">
			{
				links.map((link) => (
					<a href={link.href} class={isActive(link.href) ? 'active' : ''}>
						<svg class="link-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path d={icons[link.icon]} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
						<span>{link.label}</span>
					</a>
				))
			}
		</nav>

		<div class="header-tools" aria-label="Opciones de interfaz">
			<button class="tool-button" type="button" aria-label="Cambiar idioma">
				<svg class="tool-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M12 3a9 9 0 1 0 0 18m0-18c2.25 2.25 3.75 5.625 3.75 9S14.25 18.75 12 21m0-18c-2.25 2.25-3.75 5.625-3.75 9S9.75 18.75 12 21m-8.25-9h16.5M3.75 7.5h16.5m-16.5 9h16.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<span>ES / EN</span>
			</button>

			<button class="tool-button" type="button" aria-label="Cambiar modo de color">
				<svg class="tool-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M12 3.75V5.25m0 13.5v1.5M5.636 5.636l1.06 1.06m10.608 10.608 1.06 1.06M3.75 12h1.5m13.5 0h1.5M5.636 18.364l1.06-1.06m10.608-10.608 1.06-1.06M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<span>Claro / Oscuro</span>
			</button>
		</div>

	
	</div>

	<nav id="mobile-nav" class="mobile-nav" aria-label="Navegación móvil">
		{
			links.map((link) => (
				<a href={link.href} class={isActive(link.href) ? 'active' : ''}>
					<svg class="link-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d={icons[link.icon]} stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>{link.label}</span>
				</a>
			))
		}

		<div class="mobile-tools" aria-label="Opciones de interfaz">
			<button class="tool-button" type="button" aria-label="Cambiar idioma">
				<svg class="tool-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M12 3a9 9 0 1 0 0 18m0-18c2.25 2.25 3.75 5.625 3.75 9S14.25 18.75 12 21m0-18c-2.25 2.25-3.75 5.625-3.75 9S9.75 18.75 12 21m-8.25-9h16.5M3.75 7.5h16.5m-16.5 9h16.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<span>ES / EN</span>
			</button>

			<button class="tool-button" type="button" aria-label="Cambiar modo de color">
				<svg class="tool-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M12 3.75V5.25m0 13.5v1.5M5.636 5.636l1.06 1.06m10.608 10.608 1.06 1.06M3.75 12h1.5m13.5 0h1.5M5.636 18.364l1.06-1.06m10.608-10.608 1.06-1.06M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
				<span>Claro / Oscuro</span>
			</button>
		</div>
	</nav>
</header>

<script>
	const header = document.querySelector('.site-header');
	const button = header?.querySelector('.menu-toggle');
	const mobileNav = header?.querySelector('.mobile-nav');

	if (button && mobileNav) {
		button.addEventListener('click', () => {
			const isOpen = button.getAttribute('aria-expanded') === 'true';
			button.setAttribute('aria-expanded', String(!isOpen));
			header?.toggleAttribute('data-open');
		});

		mobileNav.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				button.setAttribute('aria-expanded', 'false');
				header?.removeAttribute('data-open');
			});
		});
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: blur(10px);
		background: rgba(255, 255, 255, 0.9);
		border-bottom: 1px solid #e6e8ec;
	}

	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0.75rem 1rem;
		display: grid;
		grid-template-columns: auto 1fr auto auto;
		align-items: center;
		gap: 1rem;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
		color: #0f172a;
		font-weight: 800;
	}

	.brand-mark {
		width: 2rem;
		height: 2rem;
		border-radius: 0.6rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: #0f172a;
		color: #ffffff;
		font-size: 0.95rem;
	}

	.brand-text {
		letter-spacing: 0.2px;
	}

	.desktop-nav {
		display: flex;
		justify-content: center;
		gap: 0.35rem;
	}

	.header-tools {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
	}

	.tool-button {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.5rem 0.75rem;
		border-radius: 999px;
		border: 1px solid #e2e8f0;
		background: #ffffff;
		color: #334155;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.tool-button:hover {
		background: #f8fafc;
		border-color: #cfd8e3;
		color: #0f172a;
	}

	.tool-icon {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
	}

	.desktop-nav a,
	.mobile-nav a {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		padding: 0.5rem 0.8rem;
		border-radius: 999px;
		text-decoration: none;
		color: #334155;
		font-weight: 600;
		border: 1px solid transparent;
		transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}

	.link-icon {
		width: 1rem;
		height: 1rem;
		flex-shrink: 0;
	}

	.desktop-nav a:hover,
	.mobile-nav a:hover {
		background: #f8fafc;
		border-color: #e2e8f0;
		color: #0f172a;
	}

	.desktop-nav a.active,
	.mobile-nav a.active {
		background: #f8fafc;
		border-color: #dbe1e8;
		color: #0f172a;
	}

	.cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		text-decoration: none;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.95rem;
		color: #ffffff;
		background: linear-gradient(135deg, #111827, #374151);
		box-shadow: 0 8px 20px rgba(17, 24, 39, 0.2);
	}

	.cta-icon {
		width: 1rem;
		height: 1rem;
	}

	.cta:hover {
		filter: brightness(1.08);
	}

	.menu-toggle {
		display: none;
		border: 1px solid #dbe1e8;
		background: #ffffff;
		border-radius: 0.6rem;
		padding: 0.45rem;
		cursor: pointer;
	}

	.menu-toggle span {
		display: block;
		width: 1.1rem;
		height: 2px;
		background: #0f172a;
		margin: 3px 0;
	}

	.mobile-nav {
		display: none;
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1rem 1rem;
		gap: 0.4rem;
		flex-direction: column;
	}

	.mobile-cta {
		margin-top: 0.4rem;
	}

	.mobile-tools {
		display: none;
		margin-top: 0.5rem;
		gap: 0.45rem;
		flex-wrap: wrap;
	}

	@media (max-width: 900px) {
		.header-inner {
			grid-template-columns: auto 1fr auto;
			justify-content: space-between;
		}

		.desktop-nav,
		.cta,
		.header-tools {
			display: none;
		}

		.menu-toggle {
			display: inline-block;
		}

		.site-header[data-open] .mobile-nav {
			display: flex;
		}

		.site-header[data-open] .mobile-tools {
			display: flex;
		}
	}
</style>