function resolveStructuredTranslation(lang, key) {
	if (!structuredTranslations[lang]) return undefined;
	const parts = key.split('-');
	if (parts[0] === 'offer' && parts.length >= 3) {
		const idx = Number(parts[1]);
		const field = parts.slice(2).join('-');
		const offer = structuredTranslations[lang].offers?.[idx];
		if (!offer) return undefined;
		if (field.startsWith('feature')) {
			const featureIdx = Number(parts[3]);
			return offer.features?.[featureIdx];
		}
		return offer[field];
	}
	if (parts[0] === 'social' && parts[2] === 'label') {
		return structuredTranslations[lang].socialStats?.[Number(parts[1])];
	}
	if (parts[0] === 'perk' && parts.length === 3) {
		const perk = structuredTranslations[lang].perks?.[Number(parts[1])];
		return perk?.[parts[2]];
	}
	if (parts[0] === 'testimonial' && parts.length === 3) {
		const t = structuredTranslations[lang].testimonials?.[Number(parts[1])];
		return t?.[parts[2]];
	}
	if (parts[0] === 'sample' && parts.length === 2) {
		return structuredTranslations[lang].sampleImages?.[Number(parts[1])];
	}
	if (parts[0] === 'included' && parts.length === 3) {
		const inc = structuredTranslations[lang].included?.[Number(parts[1])];
		return inc?.[parts[2]];
	}
	if (parts[0] === 'step' && parts.length === 3) {
		const step = structuredTranslations[lang].steps?.[Number(parts[1])];
		return step?.[parts[2]];
	}
	if (parts[0] === 'bullet' && parts.length === 2) {
		return structuredTranslations[lang].bullets?.[Number(parts[1])];
	}
	if (parts[0] === 'faq' && parts.length === 3) {
		const faq = structuredTranslations[lang].faq?.[Number(parts[1])];
		return faq?.[parts[2]];
	}
	return undefined;
}

function setLanguage(lang) {
	if (!translations[lang]) return;
	localStorage.setItem(LANG_KEY, lang);
	document.documentElement.lang = lang;

	document.querySelectorAll('[data-i18n]').forEach((el) => {
		const key = el.dataset.i18n;
		if (!key) return;
		let value = translations[lang][key];
		if (value === undefined) {
			value = resolveStructuredTranslation(lang, key);
		}
		if (value !== undefined) {
			el.textContent = value;
		}
	});
}

function toggleLanguage() {
const current = localStorage.getItem(LANG_KEY) || DEFAULT_LANG;
setLanguage(current === 'es' ? 'en' : 'es');
}

document.addEventListener('DOMContentLoaded', () => {
const initialLang = localStorage.getItem(LANG_KEY) || DEFAULT_LANG;
setLanguage(initialLang);

const languageButtons = document.querySelectorAll('.tool-button');
languageButtons.forEach((button) => button.addEventListener('click', toggleLanguage));

const header = document.querySelector('.site-header');
const menuButton = header?.querySelector('.menu-toggle');
const mobileNav = header?.querySelector('.mobile-nav');

if (menuButton && mobileNav) {
menuButton.addEventListener('click', () => {
const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
menuButton.setAttribute('aria-expanded', String(!isOpen));
header?.toggleAttribute('data-open');
});

mobileNav.querySelectorAll('a').forEach((link) => {
link.addEventListener('click', () => {
menuButton.setAttribute('aria-expanded', 'false');
header?.removeAttribute('data-open');
});
});
}
});
</script>

